---
import Band from '../components/Band.astro';
import Excerpt from '../components/Excerpt.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import Slider from '../components/Slider.jsx';
import LazyArticles from '../components/LazyArticles.jsx';
const pageTitle = "Lorem Ipsum";
const images = [
	"/img/picture_placeholder.png",
	"/img/picture_placeholder.png",
	"/img/picture_placeholder.png"
];

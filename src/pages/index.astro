		<h1 class = "centered" id = "primary-heading">{pageTitle}</h1>
		<div class = "full__three_column gap__3_rem">
			<Slider client:load>
				{images.map(image => {
					return <img src={image} alt="Placeholder image" class="slider__image" loading = "lazy" />
				})}
